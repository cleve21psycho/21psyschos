---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  /** Path to the OG image relative to the site root, e.g. "/og-image.png" */
  image?: string;
  /** Override the canonical URL (defaults to current page URL) */
  canonical?: string;
  /** "website" | "article" | etc. */
  ogType?: string;
  /** Set true to keep search engines out (e.g. drafts/staging) */
  noindex?: boolean;
}

const {
  title = "21psychos — software studio in Cape Town",
  description = "21psychos is a Cape Town software studio building modern web, mobile, and AI products. No suits, no buzzwords — just raw engineering that ships.",
  image = "/21psychos.svg",
  canonical,
  ogType = "website",
  noindex = false,
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://www.21psychos.com");
const canonicalURL = new URL(canonical ?? Astro.url.pathname, siteUrl);
const ogImageURL = new URL(image, siteUrl);

// Cape Town, South Africa
const geo = {
  region: "ZA-WC",
  placename: "Cape Town",
  position: "-33.9249;18.4241",
  icbm: "-33.9249, 18.4241",
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": ["Organization", "LocalBusiness"],
  name: "21psychos",
  url: siteUrl.toString(),
  logo: new URL("/21psychos.svg", siteUrl).toString(),
  image: ogImageURL.toString(),
  description,
  areaServed: [
    { "@type": "City", name: "Cape Town" },
    { "@type": "AdministrativeArea", name: "Western Cape" },
    { "@type": "Country", name: "South Africa" },
    { "@type": "Place", name: "Worldwide" },
  ],
  address: {
    "@type": "PostalAddress",
    addressLocality: "Cape Town",
    addressRegion: "Western Cape",
    addressCountry: "ZA",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: -33.9249,
    longitude: 18.4241,
  },
  knowsAbout: [
    "Software development",
    "Web development",
    "Mobile app development",
    "AI",
    "Product engineering",
    "Cape Town tech",
  ],
  sameAs: [],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="21psychos, Cape Town software, Cape Town software development, Cape Town developers, Cape Town web development, Cape Town tech, software studio Cape Town, South Africa software, modern tech, AI, indie tech"
    />
    <meta name="author" content="21psychos" />
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow"}
    />

    <!-- Geo targeting -->
    <meta name="geo.region" content={geo.region} />
    <meta name="geo.placename" content={geo.placename} />
    <meta name="geo.position" content={geo.position} />
    <meta name="ICBM" content={geo.icbm} />

    <link rel="canonical" href={canonicalURL.toString()} />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Theme -->
    <meta name="theme-color" content="#44ACFF" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="21psychos" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:image" content={ogImageURL.toString()} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content="en_ZA" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.toString()} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Sitemap (works once @astrojs/sitemap is installed) -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Structured data -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />

    <!-- Theme bootstrap (no FOUC) -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const theme = stored || "light";
        document.documentElement.classList.add(theme);
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>

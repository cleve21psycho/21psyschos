---
import Layout from "../layouts/Layout.astro";
import ThemeSwitcher from "$lib/components/ThemeSwitcher.svelte";
import Body from "src/components/body/Body.svelte";
import Projects from "$lib/components/Projects.svelte";
import GlitchSkull from "src/components/glitch-skull/GlitchSkull.svelte";
---

<Layout>
  <div class="min-h-screen p-8 pt-12 flex items-start justify-center">
    <main
      class="w-full max-w-5xl flex flex-col md:flex-row md:justify-between items-start"
    >
      <div class="flex justify-center py-4 md:sticky md:top-8 self-center md:self-start">
        <GlitchSkull client:load size={340} />
      </div>
      <Body client:load />
    </main>

    <div
      class="fixed bottom-0 left-0 right-0 z-50 flex items-center justify-between px-4 py-4 bg-background/95 backdrop-blur-sm"
    >
      <Projects client:load />
      <ThemeSwitcher client:load />
    </div>
  </div>
</Layout>
